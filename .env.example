# Application
APP_NAME=Ebook Niche Research API
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# API / CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=sqlite:///./ebook_niche_research.db
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ebook_niche_research

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=replace-with-a-long-random-secret

# Export storage
EXPORT_STORAGE_PATH=./artifacts/exports
EXPORT_BUCKET=ebook-niche-research-dev

# Browser automation
PLAYWRIGHT_BROWSERS_PATH=0
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=20000
PLAYWRIGHT_ACTION_TIMEOUT_MS=10000

# Marketplace scraping foundation
MARKETPLACE_SNAPSHOT_PATH=./artifacts/marketplace_snapshots
MARKETPLACE_CAPTURE_HTML=true
MARKETPLACE_CAPTURE_SCREENSHOT=false
MARKETPLACE_RATE_LIMIT_DELAY_SECONDS=0.5
MARKETPLACE_RETRY_BACKOFF_SECONDS=0.5
MARKETPLACE_MAX_RETRIES=1

# Providers
ENABLED_PROVIDERS=google_books,open_library
PROVIDER_HTTP_TIMEOUT_SECONDS=2.0
PROVIDER_HTTP_MAX_RETRIES=1
PROVIDER_HTTP_RETRY_BACKOFF_SECONDS=0.25
PROVIDER_USER_AGENT=ebook-niche-research-engine/0.1 (+local-dev)

# Environment variants
# APP_ENV=dev
# APP_ENV=staging
# APP_ENV=prod
